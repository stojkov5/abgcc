generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String       @unique
  password      String?
  role          Role         @default(MEMBER)
  createdAt     DateTime     @default(now())
  organization  String?
  position      String?
  phone         String?
  bio           String?
  photo         String?
  profileCompleted Boolean @default(false)

  // Member directory / company profile (shown in the public /members directory)
  logo               String?
  companyDescription String?
  website            String?
  industrySector     String?
  industryTags       String?
  keyContactName     String?
  keyContactTitle    String?
  keyContactEmail    String?
  address            String?
  bannerImage        String?
  featuredProjects   String?
  directoryVisible   Boolean @default(true)

  memberNumber  Int?      @unique

  emailVerified          Boolean   @default(false)
  verificationToken      String?   @unique
  verificationTokenExpiry DateTime?
  resetToken             String?   @unique
  resetTokenExpiry       DateTime?

  memberships   Membership[]
  eventBookings EventBooking[]
  payments Payment[]
}

model MembershipTier {
  id          String       @id @default(cuid())
  title       String       @unique
  description String
  price       Float
  period      String
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())

  memberships Membership[]
  payments Payment[]
}

model Membership {
  id          String           @id @default(cuid())
  status      MembershipStatus @default(PENDING)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime         @default(now())

  paymentMethod    String   @default("CARD") // "CARD" | "BANK_TRANSFER"
  invoiceReference String?  @unique
  amount           Float?

  userId      String
  tierId      String

  user        User             @relation(fields: [userId], references: [id])
  tier        MembershipTier   @relation(fields: [tierId], references: [id])
}

model Event {
  id          String         @id @default(cuid())
  title       String
  slug        String         @unique
  description String
  location    String
  image       String

  // Pricing: nonMemberPrice is the general/public rate (0 = free for everyone).
  // memberPrice is the optional discounted rate for active members — null means
  // members pay the same as everyone; 0 means free for members.
  nonMemberPrice Float       @default(0)
  memberPrice    Float?

  capacity    Int?
  active      Boolean        @default(true)
  featured    Boolean        @default(false)
  archived Boolean @default(false)

  startDate   DateTime

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  bookings    EventBooking[]
  images      EventImage[]
}

model EventImage {
  id        String   @id @default(cuid())
  url       String
  createdAt DateTime @default(now())

  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model EventBooking {
  id          String   @id @default(cuid())

  name        String
  email       String
  company     String?
  message     String?

  status      String   @default("CONFIRMED")
  attended    Boolean  @default(false)

  reference       String?  @unique
  paid            Boolean  @default(false)
  amountPaid      Float    @default(0)
  memberNumber    Int?     // set when the member rate was claimed (login or entered number)
  stripeSessionId String?  @unique

  createdAt   DateTime @default(now())

  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Post {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String              // Puck JSON (same format as Event.description)
  coverImage  String?
  author      String?
  published   Boolean  @default(true)
  featured    Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  publishedAt DateTime @default(now())
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

enum Role {
  SUPER_ADMIN
  EDITOR
  MEMBER
}

enum MembershipStatus {
  ACTIVE
  PENDING
  EXPIRED
  CANCELLED
}

model Payment {
  id              String   @id @default(cuid())

  stripeSessionId String   @unique
  amount          Float
  currency        String   @default("usd")
  status          String

  createdAt       DateTime @default(now())

  userId          String
  tierId          String

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier            MembershipTier @relation(fields: [tierId], references: [id])
}